)
saveRDS(object = stats, file = "2026-06-03-stats.rds")
readRDS(file = "posts/ghreadme/2026-06-03-stats.rds")
readRDS(file = "2026-06-03-stats.rds")
stats <- readRDS(file = "2026-06-03-stats.rds")
library(ggplot2)
stats$stars |>
head(10) |>
ggplot(aes(
x = stargazers_count,
y = reorder(repo, stargazers_count)
)) +
geom_col(fill = "#1E5F8C") +
labs(
x = "Stars",
y = NULL,
title = "Top 10 repos by stars"
) +
theme_minimal()
punchcard_plot(
stats$commits,
repo = NULL,
date_begin = "2023-01-01",
date_end = "2026-06-01",
title = "Punchcard Plot",
point_color = "#1f6feb"
)
calendar_heatmap_plot(
stats$commits,
repo = NULL,
date_begin = "2023-01-01",
date_end = "2026-06-01",
title = "Calendar Heatmap",
week_start = c("Sunday", "Monday"),
low = "#ebedf0",
high = "#216e39"
)
calendar_heatmap_plot(
stats$commits,
repo = NULL,
date_begin = "2024-01-01",
date_end = "2026-06-01",
title = "Calendar Heatmap",
week_start = c("Sunday", "Monday"),
low = "#ebedf0",
high = "#216e39"
)
calendar_heatmap_plot(
stats$commits,
