#| label: circle_packager-r_files
#| code-fold: false
#| eval: true
r_files <- scc_by_file(pkg_path, include_ext = "r", dryness = TRUE)
#| label: filter-weighted_complexity-0
#| code-fold: false
#| eval: true
r_files <- dplyr::filter(r_files, weighted_complexity > 0)
dplyr::glimpse(r_files)
#| code-fold: false
#| eval: true
library(packcircles)
#| label: packing-circleProgressiveLayout
#| code-fold: false
#| eval: true
packing <- packcircles::circleProgressiveLayout(
r_files$weighted_complexity, sizetype = "area"
)
#| label: glimpse-packing-circleProgressiveLayout
#| code-fold: false
#| eval: true
dplyr::glimpse(packing)
#| label: bind_cols-packing-r_files
#| eval: true
packing <- dplyr::bind_cols(
packing, # circle size data
dplyr::select(r_files, # original columns
filename, weighted_complexity, dryness)
)
dplyr::glimpse(packing)
#| label: circleLayoutVertices
#| eval: true
polygons <- packcircles::circleLayoutVertices(packing, npoints = 60)
dplyr::glimpse(polygons)
r_files$filename[polygons$id]
#| label: join-polygons-r_files-id
#| eval: true
polygons <- polygons |>
dplyr::left_join(
r_files |>
dplyr::mutate(id = dplyr::row_number()) |>
dplyr::select(
id,
filename,
weighted_complexity,
dryness),
by = "id"
)
dplyr::glimpse(polygons)
#| label: circle-pack-start
#| eval: true
#| code-fold: false
#| fig-width: 10
#| out-width: '100%'
ggplot2::ggplot(polygons,
ggplot2::aes(
x = x,
y = y,
group = id,
fill = dryness)) +
ggplot2::geom_polygon(
colour = "white",
linewidth = 0.2) +
ggplot2::scale_fill_viridis_c(
name    = "DRYness\n(uloc / lines)",
option  = "viridis",
limits  = c(0, 1)
) +
ggplot2::coord_equal()
#| label: circle-pack-start
#| eval: true
#| code-fold: false
#| fig-width: 10
#| out-width: '100%'
ggplot2::ggplot(polygons,
ggplot2::aes(
x = x,
y = y,
group = id,
fill = dryness)) +
ggplot2::geom_polygon(
colour = "white",
linewidth = 0.2) +
ggplot2::scale_fill_viridis_c(
name    = "DRYness\n(uloc / lines)",
option  = "viridis",
limits  = c(0, 1)
) +
ggplot2::coord_equal() +
ggplot2::theme_void(base_size = 11)
#| label: circle-pack-static
#| eval: true
#| code-fold: false
#| fig-width: 10
#| out-width: '100%'
# for the labels
library(shadowtext)
ggplot2::ggplot(polygons,
ggplot2::aes(
x = x,
y = y,
group = id,
fill = dryness)) +
ggplot2::geom_polygon(
colour = "white",
linewidth = 0.2) +
# add text labels
shadowtext::geom_shadowtext(
data    = top_labels,
mapping = ggplot2::aes(x = x, y = y, label = filename),
inherit.aes = FALSE,
size      = 3,
colour    = "#2B2B2B",     # dark text
bg.colour = "white",       # white halo so dark text stays legible
bg.r      = 0.15,
fontface  = "bold"
) +
ggplot2::scale_fill_viridis_c(
name    = "DRYness\n(uloc / lines)",
option  = "viridis",
limits  = c(0, 1)
) +
ggplot2::coord_equal() +
ggplot2::theme_void(base_size = 11)
